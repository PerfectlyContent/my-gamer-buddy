# Database (Render provides this automatically, or set for local dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gamer_buddy

# Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Backend
PORT=5000
NODE_ENV=development

# Frontend (set in production to your Render frontend URL)
FRONTEND_URL=http://localhost:3000
